# Frontend/public variables. Only VITE_ variables are safe in React/browser code.
VITE_SUPABASE_URL="https://your_supabase_project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key_here"
VITE_SUPABASE_PROJECT_ID="your_supabase_project_id_here"

# Backend Supabase variables.
SUPABASE_URL="https://your_supabase_project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# Gemini is used only for friendly chat/explanation over retrieved data.
GEMINI_API_KEY="your_google_gemini_api_key_here"
GOOGLE_GENERATIVE_AI_API_KEY="your_google_gemini_api_key_here"
ENABLE_GEMINI_CHAT=true
ENABLE_GEMINI_IMAGE=false
ENABLE_GEMINI_FOOD_VISION=false
ENABLE_GEMINI_NUTRITION_ANALYSIS=false
MAX_GEMINI_CALLS_PER_DAY=30
USE_TEMPLATE_FALLBACK=true

# USDA FoodData Central and openFDA.
DATA_GOV_API_KEY="your_data_gov_api_key_here"
USDA_FDC_BASE_URL="https://api.nal.usda.gov/fdc/v1"
OPENFDA_BASE_URL="https://api.fda.gov"

# RxNorm has no API key. Keep calls server-side to avoid browser CORS issues.
RXNORM_BASE_URL="https://rxnav.nlm.nih.gov/REST"

# WHO ICD OAuth client credentials. Backend-only.
WHO_ICD_CLIENT_ID="your_who_icd_client_id_here"
WHO_ICD_CLIENT_SECRET="your_who_icd_client_secret_here"
WHO_ICD_TOKEN_URL="https://icdaccessmanagement.who.int/connect/token"
WHO_ICD_BASE_URL="https://id.who.int/icd"

# Edamam image/food lookup. Backend-only.
EDAMAM_APP_ID="your_edamam_app_id_here"
EDAMAM_APP_KEY="your_edamam_app_key_here"
