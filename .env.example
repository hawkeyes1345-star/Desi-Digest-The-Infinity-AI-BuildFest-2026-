# ==========================================
# Desi Digest - Environment Configuration Template
# ==========================================
# NOTE: After modifying .env or .env.local, you must restart your dev server:
# npm run dev


# ------------------------------------------
# 1. Supabase Frontend / Client Keys
# ------------------------------------------
# Public client credentials. Safe to expose in browser code.
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id-here

# ------------------------------------------
# 2. Supabase Server / Private Keys
# ------------------------------------------
# Backend client credentials. Private; do not prefix with VITE_ or expose to client.
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ------------------------------------------
# 3. Google Gemini AI API Configuration
# ------------------------------------------
# Required only on server side for Nanumoni chat and food intelligence reports.
# Prefer GOOGLE_GENERATIVE_AI_API_KEY over GEMINI_API_KEY.
GOOGLE_GENERATIVE_AI_API_KEY=your-google-gemini-api-key-here
GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ------------------------------------------
# 4. OpenRouter API Configuration
# ------------------------------------------
# Private key for OpenRouter fallback vision estimation services.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_CHAT_MODEL=openrouter/free
OPENROUTER_VISION_MODEL=openrouter/free

# ------------------------------------------
# 5. Edamam API Configuration
# ------------------------------------------
# Backend credentials for primary image food classification services.
EDAMAM_APP_ID=your-edamam-app-id-here
EDAMAM_APP_KEY=your-edamam-app-key-here

# ------------------------------------------
# 6. Data & Government APIs Configuration
# ------------------------------------------
# USDA FoodData Central and openFDA credentials.
DATA_GOV_API_KEY=your-data-gov-api-key-here
USDA_FDC_BASE_URL=https://api.nal.usda.gov/fdc/v1
OPENFDA_BASE_URL=https://api.fda.gov

# RxNorm is a public medicine database (no key required).
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST

# ------------------------------------------
# 7. WHO ICD API (International Classification of Diseases)
# ------------------------------------------
# Backend credentials for health condition and symptom tagging.
WHO_ICD_CLIENT_ID=your-who-icd-client-id-here
WHO_ICD_CLIENT_SECRET=your-who-icd-client-secret-here
WHO_ICD_TOKEN_URL=https://icdaccessmanagement.who.int/connect/token
WHO_ICD_BASE_URL=https://id.who.int/icd

# ------------------------------------------
# 8. Chat & Diagnosis Feature Flags / Cooldown limits
# ------------------------------------------
ENABLE_GEMINI_CHAT=true
USE_TEMPLATE_FALLBACK=true
MAX_GEMINI_CALLS_PER_DAY=30
DEBUG_ANALYSIS=false

# ------------------------------------------
# 9. Smart Health Nudge Configuration
# ------------------------------------------
SMART_NUDGE_AI_ENABLED=true
SMART_NUDGE_AI_VERIFY=true
SMART_NUDGE_IMAGE_FETCH_ENABLED=true
